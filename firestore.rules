rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════════

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    function isBeautifulAdmin() {
      return isLoggedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.beautiful == true;
    }

    function isSuperAdmin() {
      return isBeautifulAdmin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "super_admin";
    }

    function isFinanceAdmin() {
      return isBeautifulAdmin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "finance_admin";
    }

    function isFounder() {
      return isLoggedIn() && (
        (exists(/databases/$(database)/documents/founders/$(request.auth.uid))
         && get(/databases/$(database)/documents/founders/$(request.auth.uid)).data.beautiful == true)
        ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid))
         && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.beautiful == true
         && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "founder")
      );
    }

    function hasPermission(section) {
      return isBeautifulAdmin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissions[section] == true;
    }

    // ════════════════════════════════════════════════════════════════════
    // USER ACTIVITY LOGS  — Server-side Admin SDK writes ONLY
    // Firestore rules: write = false for ALL clients. Only founders can read.
    // ════════════════════════════════════════════════════════════════════

    match /user_activity_logs/{uid} {
      allow read: if isFounder() || isSuperAdmin();
      allow write: if false; // Admin SDK only (via /api/log-activity)
    }

    match /user_activity_logs/{uid}/events/{eventId} {
      allow read: if isFounder() || isSuperAdmin();
      allow write: if false; // Admin SDK only (via /api/log-activity)
    }

    // ════════════════════════════════════════════════════════════════════
    // CUSTOMERS (Public users / store customers)
    // ════════════════════════════════════════════════════════════════════

    match /customers/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isFounder()
                   || hasPermission('customers');
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
                    (
                      // Allow if name fields are not being changed
                      (
                        (!('name' in request.resource.data) || request.resource.data.name == resource.data.name) &&
                        (!('firstName' in request.resource.data) || request.resource.data.firstName == resource.data.firstName) &&
                        (!('lastName' in request.resource.data) || request.resource.data.lastName == resource.data.lastName)
                      ) ||
                      // OR: name change is allowed (30-day rule + timestamp set)
                      (
                        (!('lastNameChange' in resource.data) ||
                         request.time > resource.data.lastNameChange + duration.value(30, 'd')) &&
                        request.resource.data.lastNameChange == request.time
                      )
                    );
      allow delete: if isSuperAdmin() || isFounder();
    }

    // ════════════════════════════════════════════════════════════════════
    // ORDERS
    // ════════════════════════════════════════════════════════════════════

    match /orders/{orderId} {
      allow read: if (isLoggedIn() && resource.data.customerId == request.auth.uid)
                   || isBeautifulAdmin() || isFounder() || hasPermission('orders');
      allow write: if isBeautifulAdmin() || isFounder() || hasPermission('orders');
    }

    match /orders/{year}/{month}/{day}/items/{orderId} {
      allow read: if (isLoggedIn() && resource.data.customerId == request.auth.uid)
                   || isBeautifulAdmin() || isFounder() || hasPermission('orders');
      allow write: if isBeautifulAdmin() || isFounder() || hasPermission('orders'); // Allow admins to update payments
    }

    match /orders/{year}/{month}/{day} {
      allow read: if isBeautifulAdmin() || isFounder() || hasPermission('orders');
    }

    // ════════════════════════════════════════════════════════════════════
    // PRODUCTS & INVENTORY
    // ════════════════════════════════════════════════════════════════════

    match /products/{id} {
      allow read: if true; // Public catalog
      allow write: if isSuperAdmin() || isFounder() || hasPermission('products');
    }

    match /inventory/{id} {
      allow read: if isBeautifulAdmin() || isFounder() || hasPermission('inventory');
      allow write: if isBeautifulAdmin() || isFounder() || hasPermission('inventory');
    }

    // ════════════════════════════════════════════════════════════════════
    // SETTINGS
    // ════════════════════════════════════════════════════════════════════

    match /settings/company {
      allow read: if true; // Public for checkout fees
      allow write: if isBeautifulAdmin() || isFounder();
    }

    match /settings/{doc} {
      allow read: if isBeautifulAdmin() || isFounder();
      allow write: if isSuperAdmin() || isFounder();
    }

    // ════════════════════════════════════════════════════════════════════
    // ADMIN & TEAM MANAGEMENT
    // ════════════════════════════════════════════════════════════════════

    match /admins/{adminId} {
      // Admins can read their own profile; founders/super can read all
      allow read: if isOwner(adminId) || isBeautifulAdmin() || isFounder();
      // Only founders and super_admins can provision/modify team members
      allow create: if isSuperAdmin() || isFounder();
      allow update: if isSuperAdmin() || isFounder();
      allow delete: if isFounder(); // Founders only for deletions
    }

    match /founders/{founderId} {
      allow read: if isOwner(founderId) || isSuperAdmin();
      allow write: if false; // Console only — never from client
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isFounder();
      allow write: if isOwner(userId) || isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // FINANCIAL DATA
    // ════════════════════════════════════════════════════════════════════

    match /transactions/{year}/{month}/items/{id} {
      allow read: if isFinanceAdmin() || isSuperAdmin() || isFounder()
                   || hasPermission('finance');
      allow write: if false;
    }

    match /expenses/{year}/{month}/items/{id} {
      allow read: if isFinanceAdmin() || isSuperAdmin() || isFounder()
                   || hasPermission('finance');
      allow write: if false;
    }

    match /founder_withdrawals/{id} {
      allow read: if isFounder() || isSuperAdmin();
      allow write: if false;
    }

    match /finance_verifications/{id} {
      allow read: if isFinanceAdmin() || isSuperAdmin() || isFounder() || hasPermission('finance');
      allow write: if isBeautifulAdmin() || isFounder() || hasPermission('orders');
    }

    // ════════════════════════════════════════════════════════════════════
    // TASK SYSTEM
    // ════════════════════════════════════════════════════════════════════

    match /tasks/{taskId} {
      allow read: if isBeautifulAdmin() || isFounder() || hasPermission('tasks');
      allow write: if isBeautifulAdmin() || isFounder() || hasPermission('tasks');
    }

    match /tasks/{taskId}/history/{id} {
      allow read: if isBeautifulAdmin() || isFounder();
      allow write: if isBeautifulAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // AUDIT LOGS
    // ════════════════════════════════════════════════════════════════════

    match /admin_logs/{year}/{month}/items/{id} {
      allow read: if isSuperAdmin() || isFounder() || hasPermission('logs');
      allow write: if false; // Admin SDK only
    }

    match /activity_logs/{year}/{month}/{id} {
      allow read: if isBeautifulAdmin() || isFounder() || hasPermission('logs');
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // DIGITAL DELIVERIES
    // ════════════════════════════════════════════════════════════════════

    match /digital_deliveries/{orderId}/items/{itemId} {
      allow read: if (isLoggedIn() && request.auth.uid == resource.data.userId)
                   || isSuperAdmin() || isFounder();
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // ANALYTICS
    // ════════════════════════════════════════════════════════════════════

    match /analytics/daily/records/{id} {
      allow read: if isFinanceAdmin() || isSuperAdmin() || isFounder()
                   || hasPermission('analytics');
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // CUSTOMER PROFILES (Legacy — kept for compatibility)
    // ════════════════════════════════════════════════════════════════════

    match /customer_profiles/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isFounder();
      allow write: if isOwner(userId);
    }
  }
}
