                            return `
                                <div class="order-card" id="order-${o.id}">
                                    <div class="order-header">
                                        <div>
                                            <span class="order-id">#${o.id.slice(0, 8).toUpperCase()}</span>
                                            <div style="font-size:0.7rem; color:var(--text-dim); margin-top:4px;">${subInfo} ${estTime}</div>
                                        </div>
                                        <span class="order-status status-${status}">${STATUS_LABELS[status]}</span>
                                    </div>
                                    <div class="order-body">${itemsHtml}</div>
                                    ${deliveryArea}
                                    <div class="order-footer">
                                        <span class="o-date">${formatDate(o.createdAt)}</span>
                                        <div style="display:flex; align-items:center; gap:16px;">
                                            ${status !== 'pending' ? `<button class="o-action-btn" onclick="window.prepareReceipt('${o.id}')" style="padding:6px 12px; border-radius:8px;">Print Receipt</button>` : ''}
                                            <span class="o-total">৳${(o.totalAmount || 0).toLocaleString()}</span>
                                        </div>
                                    </div>
                                </div>`;
                        }).join('');

                        // Add "Shop More" at the bottom of the list
                        ordersList.innerHTML += `
                            <div style="text-align:center; padding: 2rem 0; margin-top:1rem; border-top:1px solid rgba(255,255,255,0.05);">
                                <a href="/store" class="shop-btn" style="text-decoration:none; display:inline-block; font-size:1rem; padding:12px 30px;">Shop More Assets</a>
                            </div>
                        `;
                    }
                } else {
                    if (ordersEmpty) ordersEmpty.classList.remove('hidden');
                    if (recentOrdersCard) recentOrdersCard.classList.add('hidden');
                    const noOrdersCard = document.getElementById('noOrdersCard');
                    if (noOrdersCard) noOrdersCard.classList.remove('hidden');
                }
            } catch (err) { 
                console.error('Data loading error:', err);
                if (ordersLoading) ordersLoading.classList.add('hidden');
            }
        };

        (window as any).prepareReceipt = (orderId: string) => {
            const order = (window as any)._allOrders?.find((o: any) => o.id === orderId);
            if (!order) return;
            
            const printArea = document.getElementById('receipt-print-wrapper');
            if (!printArea) return;

            const itemsRows = (order.items || []).map((i: any) => `
                <tr>
                    <td>
                        <div style="font-weight: 700;">${i.title}</div>
