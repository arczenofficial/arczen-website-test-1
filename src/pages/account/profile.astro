    function formatDate(ts: any): string {
        if (!ts) return '—';
        const d = ts.toDate ? ts.toDate() : new Date(ts);
        return d.toLocaleDateString('en-BD', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    const STATUS_LABELS: Record<string, string> = {
        pending:     'Waiting Verification',
        received:    'Payment Received',
        confirmed:   'Payment Verified',
        in_progress: 'Work in Progress',
        processing:  'Processing',
        shipped:     'Shipped',
        delivered:   'Order Delivered',
        cancelled:   'Cancelled',
    };

    const STATUS_SUBTEXT: Record<string, string> = {
        pending:     'Our admins will verify your payment soon.',
        received:    'Payment Received - Work is Pending',
        confirmed:   'Payment Verified - Work in Queueing...',
        in_progress: 'Our team is currently preparing your assets.',
        delivered:   'Your digital assets are ready below.',
    };

    onAuthStateChanged(clientAuth, async (user) => {
        const loadingScreen = document.getElementById('authLoading');
        const profileContent = document.getElementById('profileContent');
        
        if (loadingScreen) loadingScreen.classList.add('hidden');
        if (!user) { window.location.replace('/account/login'); return; }
        if (profileContent) profileContent.classList.remove('hidden');

        // Log page_viewed — fire and forget
        logActivity('page_viewed', { page: '/account/profile', tab: 'overview' });

        // State Manager
        let currentAddresses = [];
        let editingAddrIndex = -1;
        let originalProfile = null;

        // Security Provider Logic
        const isGoogle = user.providerData.some(p => p.providerId === 'google.com');
        const googleBadge = document.getElementById('googleBadge');
        const resetActions = document.getElementById('resetActions');
        const changePasswordForm = document.getElementById('changePasswordForm');
        const secDescription = document.getElementById('secDescription');

        if (isGoogle) {
            googleBadge?.classList.remove('hidden');
            resetActions?.classList.add('hidden');
            secDescription?.classList.add('hidden');
        } else {
            changePasswordForm?.classList.remove('hidden');
            resetActions?.classList.add('hidden');
            if (secDescription) secDescription.textContent = 'Enter your current and new password to update.';
        }

        // Tab Switching Logic
        const tabBtns = document.querySelectorAll('#profileTabs .pnav-item[data-tab]');
        const tabContents = document.querySelectorAll('.tab-content');

        tabBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const targetTab = btn.getAttribute('data-tab');
                tabBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                tabContents.forEach(content => {
                    content.classList.toggle('hidden', content.id !== `tab-${targetTab}`);
                });
                logActivity('page_viewed', { page: '/account/profile', tab: targetTab || 'unknown' });
            });
        });

        // Basic Info Setup
        const initials = (user.displayName || user.email || 'A').charAt(0).toUpperCase();
        const avatarCircle = document.getElementById('avatarCircle');
        const sidebarDisplayName = document.getElementById('sidebarDisplayName');
        const profileEmail = document.getElementById('profileEmail');
        const editEmailInput = document.getElementById('editEmail') as HTMLInputElement;

        if (avatarCircle) avatarCircle.textContent = initials;
        if (sidebarDisplayName) sidebarDisplayName.textContent = user.displayName || 'ArcZen Member';
        if (profileEmail) profileEmail.textContent = user.email || '';
        if (editEmailInput) editEmailInput.value = user.email || '';

        // Address Rendering Helper
        const renderAddresses = () => {
            const list = document.getElementById('addressList');
            if (!list) return;
            
            if (!currentAddresses || currentAddresses.length === 0) {
                list.innerHTML = '<p style="color: var(--text-dim); font-size: 0.9rem; padding: 1rem;">No addresses saved yet.</p>';
                return;
            }

            list.innerHTML = currentAddresses.map((addr: any, index: number) => `
                <div class="address-item ${addr.isDefault ? 'default' : ''}">
                    <div class="addr-info">
                        <span class="addr-tag">${addr.label || 'Other'}</span>
                        <div class="addr-text">${addr.street}, ${addr.city}, ${addr.district}</div>
                        ${addr.isDefault ? '<div class="addr-meta"><span style="color: var(--gold); font-weight: 700;">• Default Address</span></div>' : ''}
                    </div>
                    <div class="addr-actions">
                        <button type="button" class="addr-btn edit" data-index="${index}">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </button>
                        <button type="button" class="addr-btn delete" data-index="${index}" ${currentAddresses.length === 1 ? 'disabled style="opacity: 0.2;"' : ''}>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        </button>
                    </div>
                </div>
            `).join('');

            // Attach listeners
            list.querySelectorAll('.addr-btn.edit').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const idx = parseInt((e.currentTarget as HTMLElement).dataset.index!);
                    startEditAddress(idx);
                });
            });
            list.querySelectorAll('.addr-btn.delete').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const idx = parseInt((e.currentTarget as HTMLElement).dataset.index!);
                    if (confirm('Are you sure you want to delete this address?')) {
                        const wasDefault = currentAddresses[idx].isDefault;
                        currentAddresses.splice(idx, 1);
                        if (wasDefault && currentAddresses.length > 0) currentAddresses[0].isDefault = true;
                        renderAddresses();
                    }
                });
            });
        };

        const startEditAddress = (index = -1) => {
            editingAddrIndex = index;
            const section = document.getElementById('addressEditSection')!;
            const title = document.getElementById('addrFormTitle')!;
            const label = document.getElementById('addrLabel') as HTMLSelectElement;
            const street = document.getElementById('addrStreet') as HTMLTextAreaElement;
            const city = document.getElementById('addrCity') as HTMLInputElement;
            const district = document.getElementById('addrDistrict') as HTMLInputElement;

            section.classList.remove('hidden');
            if (index > -1) {
                const a = currentAddresses[index];
                title.textContent = 'Edit Address';
                label.value = a.label;
                street.value = a.street;
                city.value = a.city;
                district.value = a.district;
            } else {
                title.textContent = 'Add New Address';
                label.value = 'Home';
                street.value = '';
                city.value = '';
                district.value = '';
            }
            section.scrollIntoView({ behavior: 'smooth' });
        };

        // Address Form Handlers
        document.getElementById('addAddressBtn')?.addEventListener('click', () => startEditAddress());
        document.getElementById('cancelAddrBtn')?.addEventListener('click', () => {
            document.getElementById('addressEditSection')?.classList.add('hidden');
        });
        document.getElementById('saveAddrBtn')?.addEventListener('click', () => {
            const label = (document.getElementById('addrLabel') as HTMLSelectElement).value;
            const street = (document.getElementById('addrStreet') as HTMLTextAreaElement).value.trim();
            const city = (document.getElementById('addrCity') as HTMLInputElement).value.trim();
            const district = (document.getElementById('addrDistrict') as HTMLInputElement).value.trim();

            if (!street || !city || !district) { alert('Please fill in all address fields.'); return; }

            const newAddr = { label, street, city, district, isDefault: currentAddresses.length === 0 };

            if (editingAddrIndex > -1) {
                currentAddresses[editingAddrIndex] = { ...currentAddresses[editingAddrIndex], ...newAddr };
            } else {
                currentAddresses.push(newAddr);
            }

            document.getElementById('addressEditSection')?.classList.add('hidden');
            renderAddresses();
        });

        // UI Update Helper
        const updateUIWithData = (data: any) => {
            originalProfile = data;
            const fullName = data.name || user.displayName || 'ArcZen Member';
            const heroWelcome = document.getElementById('heroWelcome');
            const viewEmail = document.getElementById('viewEmail');
            const viewPhone = document.getElementById('viewPhone');
            const viewJoined = document.getElementById('viewJoined');
            const viewAddress = document.getElementById('viewAddress');

            const firstName = data.firstName || fullName.split(' ')[0];
            if (heroWelcome) heroWelcome.textContent = `Welcome back, ${firstName}`;
            if (viewEmail) viewEmail.textContent = user.email || '—';
            if (viewPhone) viewPhone.textContent = data.phone || 'Not provided';
            if (viewJoined) {
                const joinedDate = data.createdAt ? formatDate(data.createdAt) : 'Member';
                viewJoined.textContent = joinedDate;
            }
            
            // Addresses
            currentAddresses = data.addresses || [];
            if (currentAddresses.length === 0 && data.address) {
                // Migrate old address if exists
                currentAddresses = [{ label: 'Home', street: data.address, city: 'Unknown', district: 'Unknown', isDefault: true }];
            }
            
            const defAddr = currentAddresses.find((a: any) => a.isDefault) || currentAddresses[0];
            if (viewAddress) {
                viewAddress.textContent = defAddr ? `${defAddr.street}\n${defAddr.city}, ${defAddr.district}` : 'No address saved yet';
            }
            renderAddresses();

            if (sidebarDisplayName) sidebarDisplayName.textContent = fullName;

            // Name Change Rule Enforcement
            const warning = document.getElementById('nameChangeWarning');
            const fNameInput = document.getElementById('firstName') as HTMLInputElement;
            const lNameInput = document.getElementById('lastName') as HTMLInputElement;
            const fLocked = document.getElementById('firstNameLocked');
            const lLocked = document.getElementById('lastNameLocked');

            if (data.lastNameChange) {
                const lastChange = data.lastNameChange.toDate ? data.lastNameChange.toDate() : new Date(data.lastNameChange);
                const thirtyDays = 30 * 24 * 60 * 60 * 1000;
                const nextEligible = lastChange.getTime() + thirtyDays;
                const now = new Date().getTime();

                if (now < nextEligible) {
                    const daysLeft = Math.ceil((nextEligible - now) / (1000 * 60 * 60 * 24));
                    fNameInput.classList.add('disabled-input', 'field-locked');
                    lNameInput.classList.add('disabled-input', 'field-locked');
                    fLocked?.classList.remove('hidden');
                    lLocked?.classList.remove('hidden');
                    if (fLocked) fLocked.textContent = `Locked for ${daysLeft} more days`;
                    if (lLocked) lLocked.textContent = `Locked for ${daysLeft} more days`;
                    warning?.classList.add('hidden');
                } else {
                    warning?.classList.remove('hidden');
                    fNameInput.classList.remove('disabled-input', 'field-locked');
                    lNameInput.classList.remove('disabled-input', 'field-locked');
                }
            } else {
                warning?.classList.remove('hidden');
            }

            // Update Settings Inputs
            const phoneInput = document.getElementById('phone') as HTMLInputElement;
            const countryCodeSelect = document.getElementById('countryCode') as HTMLSelectElement;

            if (fNameInput) fNameInput.value = data.firstName || fullName.split(' ')[0] || '';
            if (lNameInput) lNameInput.value = data.lastName || fullName.split(' ').slice(1).join(' ') || '';

            if (phoneInput && countryCodeSelect && data.phone) {
                const match = data.phone.match(/^(\+\d+)\s*(.*)$/);
                if (match) {
                    countryCodeSelect.value = match[1];
                    phoneInput.value = match[2];
                } else {
                    phoneInput.value = data.phone;
                }
            }
        };

        // Fetch Main Data
        const loadProfileData = async () => {
            const ordersLoading = document.getElementById('ordersLoading');
            const ordersEmpty = document.getElementById('ordersEmpty');
            const ordersList = document.getElementById('ordersList');
            const recentOrdersCard = document.getElementById('recentOrdersCard');
            const recentOrdersMiniList = document.getElementById('recentOrdersMiniList');

            try {
                onSnapshot(doc(clientDb, 'customers', user.uid), (snap) => {
                    if (snap.exists()) updateUIWithData(snap.data());
                    else updateUIWithData({});
                });

                const ordersQ = query(collection(clientDb, 'orders'), where('customerId', '==', user.uid));
                const ordersSnap = await getDocs(ordersQ);
                const orders = ordersSnap.docs.map(d => ({ id: d.id, ...d.data() }));
                (window as any)._allOrders = orders;
                
                if (ordersLoading) ordersLoading.classList.add('hidden');

                if (!ordersSnap.empty) {
                    orders.sort((a: any, b: any) => {
                        const dateA = a.createdAt?.seconds || (a.createdAt instanceof Date ? a.createdAt.getTime() / 1000 : 0);
                        const dateB = b.createdAt?.seconds || (b.createdAt instanceof Date ? b.createdAt.getTime() / 1000 : 0);
                        return dateB - dateA;
                    });

                    // 1. Overview Tab: Recent Orders Mini Card
                    const activeOrdersList = orders.filter((o: any) => ['pending', 'received', 'confirmed', 'in_progress', 'processing', 'shipped'].includes(o.status));
                    const activeOrder = activeOrdersList[0];

                    if (recentOrdersCard && recentOrdersMiniList) {
                        if (activeOrdersList.length > 0) {
                            recentOrdersCard.classList.remove('hidden');
                            const h3 = recentOrdersCard.querySelector('h3');
                            if (h3) h3.textContent = 'Active Orders';
                            const top3 = activeOrdersList.slice(0, 3);
                            recentOrdersMiniList.innerHTML = top3.map((o: any) => `
                                <div class="mini-order-item" onclick="document.querySelector('[data-tab=orders]').click(); setTimeout(() => { document.getElementById('order-${o.id}')?.scrollIntoView({behavior:'smooth'}) }, 100)">
                                    <div class="mo-info">
                                        <span class="mo-id">#${o.id.slice(0, 8).toUpperCase()}</span>
                                        <span class="mo-status status-${o.status}" style="background:none; border:none; padding:0; font-size:0.65rem;">${STATUS_LABELS[o.status] || o.status}</span>
                                    </div>
                                    <div class="mo-arrow">→</div>
                                </div>
                            `).join('');
                        } else {
                            recentOrdersCard.classList.add('hidden');
                        }
                    }

                    // 2. Overview Tab: Active Order Box
                    const activeOrderStatusText = document.getElementById('activeOrderStatusText');
                    const activeOrderPulse = document.getElementById('activeOrderPulse');
                    const activeOrderBtn = document.getElementById('activeOrderBtn') as HTMLAnchorElement;

                    if (activeOrder) {
                        const baseText = `Current: Order #${activeOrder.id.slice(0,8).toUpperCase()} is ${STATUS_LABELS[activeOrder.status]}`;
                        const subText = STATUS_SUBTEXT[activeOrder.status] ? ` — ${STATUS_SUBTEXT[activeOrder.status]}` : '';
                        if (activeOrderStatusText) activeOrderStatusText.textContent = baseText + subText;
                        if (activeOrderPulse) activeOrderPulse.classList.remove('hidden');
                        if (activeOrderBtn) {
                            activeOrderBtn.textContent = 'Manage Order';
                            activeOrderBtn.href = '#';
                            activeOrderBtn.onclick = (e) => {
                                e.preventDefault();
                                document.querySelector('[data-tab=orders]').click();
                                setTimeout(() => { document.getElementById('order-' + activeOrder.id)?.scrollIntoView({behavior:'smooth'}) }, 100);
                            };
                        }
                    } else {
                        if (activeOrderStatusText) activeOrderStatusText.textContent = `You haven't ordered any current purchases.`;
                        if (activeOrderPulse) activeOrderPulse.classList.add('hidden');
                        if (activeOrderBtn) {
                            activeOrderBtn.textContent = 'Make your first order';
                            activeOrderBtn.href = '/store';
                            activeOrderBtn.onclick = (e) => {
                                e.preventDefault();
                                window.location.href = '/store';
                            };
                        }
                    }

                    // 3. Orders Tab: Full List
                    if (ordersList) {
                        ordersList.innerHTML = orders.map((o: any) => {
                            const status = o.status || 'pending';
                            const itemsHtml = (o.items || []).map((item: any, idx: number) => `
                                <div class="order-item">
                                    <img src="${item.image || '/assets/images/logo-placeholder.svg'}" class="item-img" onerror="this.src='/assets/images/logo-placeholder.svg'">
                                    <div class="item-info"><span class="item-name">${item.title}</span><span class="item-variant">${item.variant || 'Standard'}</span></div>
                                    <div class="item-price-qty"><div>৳${(item.price || 0).toLocaleString()}</div><div style="font-size: 0.75rem; color: #9a9387">Qty: ${item.quantity || 1}</div></div>
                                </div>
                                ${(o.fulfillment && o.fulfillment[item.uniqueId || item.id || idx]) ? `
                                    <div class="o-delivery-note" style="margin-top:0; margin-bottom:1rem; border-style:solid; border-width:1px;">
                                        <strong style="font-size:0.6rem;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:4px;"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.77 7.77a5.5 5.5 0 0 1 7.77-7.77zm0 0L22 22"/></svg> ITEM-SPECIFIC DELIVERY</strong>
                                        <code style="padding:0.75rem; font-size:0.75rem;">${o.fulfillment[item.uniqueId || item.id || idx].payload.replace(/\n/g, '<br>')}</code>
                                    </div>
                                ` : ''}
                            `).join('');

                            const subInfo = STATUS_SUBTEXT[status] || '';
                            const estTime = (status === 'confirmed' && o.estimatedTime) ? `<div style="font-size:0.8rem; color: var(--gold); margin-top:0.5rem;">🕒 Estimated Arrival: <strong>${o.estimatedTime}</strong></div>` : '';

                            const deliveryArea = (o.deliveryInfo) ? `
                                <div class="o-delivery-note">
                                    <strong><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:4px;"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.77 7.77 5.5 5.5 0 0 1 7.77-7.77zm0 0L22 22"/></svg> GLOBAL DELIVERY NOTES</strong>
                                    <code>${o.deliveryInfo.replace(/\n/g, '<br>')}</code>
                                    <p style="font-size:0.65rem; color:var(--text-dim); margin-top:10px;">* Please check both item-specific and global notes for your credentials.</p>
                                </div>
                            ` : '';

                            return `
                                <div class="order-card" id="order-${o.id}">
                                    <div class="order-header">
                                        <div>
                                            <span class="order-id">#${o.id.slice(0, 8).toUpperCase()}</span>
                                            <div style="font-size:0.7rem; color:var(--text-dim); margin-top:4px;">${subInfo} ${estTime}</div>
                                        </div>
                                        <span class="order-status status-${status}">${STATUS_LABELS[status]}</span>
                                    </div>
                                    <div class="order-body">${itemsHtml}</div>
                                    ${deliveryArea}
                                    <div class="order-footer">
                                        <span class="o-date">${formatDate(o.createdAt)}</span>
                                        <div style="display:flex; align-items:center; gap:16px;">
                                            ${status !== 'pending' ? `<button class="o-action-btn" onclick="window.prepareReceipt('${o.id}')" style="padding:6px 12px; border-radius:8px;">Print Receipt</button>` : ''}
                                            <span class="o-total">৳${(o.totalAmount || 0).toLocaleString()}</span>
                                        </div>
                                    </div>
                                </div>`;
                        }).join('');

                        // Add "Shop More" at the bottom of the list
                        ordersList.innerHTML += `
                            <div style="text-align:center; padding: 2rem 0; margin-top:1rem; border-top:1px solid rgba(255,255,255,0.05);">
                                <a href="/store" class="shop-btn" style="text-decoration:none; display:inline-block; font-size:1rem; padding:12px 30px;">Shop More Assets</a>
                            </div>
                        `;
                    }
                } else {
                    if (ordersEmpty) ordersEmpty.classList.remove('hidden');
                    if (recentOrdersCard) recentOrdersCard.classList.add('hidden');
                    const noOrdersCard = document.getElementById('noOrdersCard');
                    if (noOrdersCard) noOrdersCard.classList.remove('hidden');
                }
            } catch (err) { 
                console.error('Data loading error:', err);
                if (ordersLoading) ordersLoading.classList.add('hidden');
            }
        };

        (window as any).prepareReceipt = (orderId: string) => {
            const order = (window as any)._allOrders?.find((o: any) => o.id === orderId);
            if (!order) return;
            
            const printArea = document.getElementById('receipt-print-wrapper');
            if (!printArea) return;

            const itemsRows = (order.items || []).map((i: any) => `
                <tr>
                    <td>
                        <div style="font-weight: 700;">${i.title}</div>
                        <div style="font-size: 0.7rem; color: #666; margin-top:2px;">Type: ${i.variant || 'Standard Asset'}</div>
                    </td>
                    <td>৳${(i.price || 0).toLocaleString()}</td>
                    <td>${i.quantity || 1}</td>
                    <td style="text-align:right; font-weight: 700;">৳${((i.price || 0) * (i.quantity || 1)).toLocaleString()}</td>
                </tr>
            `).join('');

            printArea.innerHTML = `
                <div class="r-header">
                    <div style="display:flex; align-items:center; gap:12px;">
                        <img src="/assets/images/logo.svg" class="r-logo" onerror="this.src='/assets/images/logo-placeholder.svg'">
                        <div style="font-weight: 900; font-size: 1.5rem; letter-spacing: -1px;">ARCZEN</div>
                    </div>
                    <div class="r-title">OFFICIAL RECEIPT</div>
                </div>
                
                <div class="r-grid">
                    <div>
                        <div class="r-label">ACCOUNT HOLDER</div>
                        <div class="r-val" style="font-size: 1.1rem; font-weight: 800; color: #000;">${order.customerName || 'N/A'}</div>
                        <div class="r-val" style="margin-top: 4px;">${order.customerEmail || ''}</div>
                        <div class="r-val">${order.customerPhone || ''}</div>
                        <div class="r-val" style="color: #666; font-size: 0.7rem; margin-top: 8px;">ADDRESS: ${order.deliveryAddress || 'DIGITAL DELIVERY'}</div>
                    </div>
                    <div>
                        <div class="r-label">BILLING & SETTLEMENT</div>
                        <div class="r-val"><strong>TRX ID:</strong> <span style="font-family:monospace;">${order.paymentTrxId || 'N/A'}</span></div>
                        <div class="r-val"><strong>METHOD:</strong> ${order.paymentMethod?.toUpperCase() || 'N/A'}</div>
                        <div class="r-val"><strong>ORDER ID:</strong> #${order.id.slice(0, 12).toUpperCase()}</div>
                    </div>
                </div>

                <div class="r-grid" style="margin-top:-20px; background: #f9f9f9; padding: 15px; border-radius: 8px;">
                    <div>
                        <div class="r-label">ORDER GENERATED</div>
                        <div class="r-val">${formatDate(order.createdAt)}</div>
                    </div>
                    <div>
                        <div class="r-label">VERIFICATION DATE</div>
                        <div class="r-val">${order.updatedAt ? formatDate(order.updatedAt) : 'Pending Settlement'}</div>
                    </div>
                </div>

                <table class="r-table">
                    <thead>
                        <tr>
                            <th style="width: 50%">Product Asset Details</th>
                            <th>Unit Price</th>
                            <th>Qty</th>
                            <th style="text-align:right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>${itemsRows}</tbody>
                </table>

                <div style="display: flex; justify-content: space-between;">
                    <div style="max-width: 300px;">
                        <div class="r-label" style="margin-bottom: 8px;">OFFICIAL STATEMENT</div>
                        <p style="font-size: 0.7rem; color: #444; line-height: 1.5;">Thank you for conducting business with ArcZen. This receipt serves as your official proof of purchase for the listed digital assets. For any support inquiries, please contact our terminal via live chat or email.</p>
                        <div style="font-weight: 800; font-size: 0.8rem; margin-top: 12px; color: #00C9BC;">WWW.ARCZEN.COM</div>
                    </div>
                    <div class="r-summary">
                        <div class="r-sum-row">
                            <span style="color:#666">Order Subtotal</span>
                            <span>৳${(order.subtotal || order.amount).toLocaleString()}</span>
                        </div>
                        <div class="r-sum-row">
                            <span style="color:#666">Service & Processing</span>
                            <span>৳${(order.processingCharge || 0).toLocaleString()}</span>
                        </div>
                        <div class="r-sum-row r-total">
                            <span>TOTAL SETTLEMENT</span>
                            <span>৳${(order.totalAmount || order.amount).toLocaleString()}</span>
                        </div>
                    </div>
                </div>

                <div class="r-footer">
                    <div style="font-weight: 800; color: #000; margin-bottom: 5px;">ARCZEN DIGITAL ASSETS | AG_SYSTEM_RECEIPT_V2</div>
                    <p>Generated on ${new Date().toLocaleString()} | NODE_LOG: ${order.id}</p>
                    <p style="margin-top: 10px; font-weight: 700;">THANK YOU FOR CHOOSING ARCZEN</p>
                </div>
            `;

            window.print();
        };

        // 4. Handle Success Redirect Info
        const params = new URLSearchParams(window.location.search);
        if (params.get('success') === '1') {
            const banner = document.getElementById('orderSuccessCelebration');
            const orderIdSpan = document.getElementById('successOrderId');
            if (banner) banner.classList.remove('hidden');
            if (orderIdSpan) orderIdSpan.textContent = `#${(params.get('id') || '').slice(0, 8).toUpperCase()}`;
            
            // Clean up URL without reload
            const newUrl = window.location.pathname + (params.get('tab') ? `?tab=${params.get('tab')}` : '');
            window.history.replaceState({}, '', newUrl);
        }

        loadProfileData();

        // Save Profile
        document.getElementById('profileForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('saveProfileBtn') as HTMLButtonElement;
            const btnText = document.getElementById('saveBtnText')!;
            
            const first = (document.getElementById('firstName') as HTMLInputElement).value.trim();
            const last  = (document.getElementById('lastName') as HTMLInputElement).value.trim();
            const country = (document.getElementById('countryCode') as HTMLSelectElement).value;
            const phone   = (document.getElementById('phone') as HTMLInputElement).value.trim();
            
            btn.disabled = true;
            btnText.textContent = 'Saving...';

            try {
                const profileData: any = {
                    phone: phone ? `${country} ${phone}` : '',
                    addresses: currentAddresses,
                    updatedAt: serverTimestamp()
                };

                // Check if name changed
                const newName = `${first} ${last}`.trim();
                const oldName = originalProfile?.name || user.displayName || '';
                
                if (newName !== oldName) {
                    profileData.firstName = first;
                    profileData.lastName = last;
                    profileData.name = newName;
                    profileData.lastNameChange = serverTimestamp(); // Required by rules
                }

                await setDoc(doc(clientDb, 'customers', user.uid), profileData, { merge: true });
                if (profileData.name) await updateProfile(user, { displayName: profileData.name });
                
                // Refresh UI
                const finalSnap = await getDoc(doc(clientDb, 'customers', user.uid));
                updateUIWithData(finalSnap.data());

                const switchTab = (tabId: string) => {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
            document.querySelectorAll('.pnav-item').forEach(t => t.classList.remove('active'));
            document.getElementById(`tab-${tabId}`)?.classList.remove('hidden');
            document.querySelector(`[data-tab="${tabId}"]`)?.classList.add('active');
            
            // Fix header overlap on desktop when switching tabs
            window.scrollTo({ top: 0, behavior: 'smooth' });
        };

                logActivity('profile_updated', { page: '/account/profile' });
                document.getElementById('saveSuccess')?.classList.remove('hidden');
                setTimeout(() => document.getElementById('saveSuccess')?.classList.add('hidden'), 3000);
            } catch (err) {
                console.error('Save error:', err);
                document.getElementById('saveError')?.classList.remove('hidden');
                setTimeout(() => document.getElementById('saveError')?.classList.add('hidden'), 4000);
            } finally {
                btn.disabled = false;
                btnText.textContent = 'Save Changes';
            }
        });

        // Change Password Form
        document.getElementById('changePasswordForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const currentPass = (document.getElementById('currentPassword') as HTMLInputElement).value;
            const newPass = (document.getElementById('newPassword') as HTMLInputElement).value;
            const btn = (e.target as HTMLFormElement).querySelector('button');
            if (!btn) return;
            
            if (newPass.length < 6) { alert('New password must be at least 6 characters.'); return; }
            
            btn.disabled = true;
            btn.textContent = 'Updating...';

            try {
                const credential = EmailAuthProvider.credential(user.email!, currentPass);
                await reauthenticateWithCredential(user, credential);
                await updatePassword(user, newPass);
                logActivity('password_changed', { page: '/account/profile' });
                alert('Password updated successfully!');
                (e.target as HTMLFormElement).reset();
            } catch (err: any) {
                console.error('Password error:', err);
                if (err.code === 'auth/wrong-password') alert('Current password is incorrect.');
                else alert('Failed to update password: ' + err.message);
            } finally {
                btn.disabled = false;
                btn.textContent = 'Update Password';
            }
        });

        // Other handlers
        document.getElementById('signOutBtn')?.addEventListener('click', async () => {
            logActivity('logout', { page: '/account/profile' });
            // Brief delay to allow the log request to fire before navigating
            await new Promise(r => setTimeout(r, 300));
            await signOut(clientAuth);
            window.location.replace('/');
        });
        document.getElementById('sendResetBtn')?.addEventListener('click', () => {
            if (user.email) {
                sendPasswordResetEmail(clientAuth, user.email).then(() => {
                    logActivity('password_reset_requested', { page: '/account/profile' });
                    document.getElementById('resetSent')?.classList.remove('hidden');
                });
            }
        });
    });
</script>

