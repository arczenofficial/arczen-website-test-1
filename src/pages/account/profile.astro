                <table class="r-table">
                    <thead>
                        <tr>
                            <th style="width: 50%">Product Asset Details</th>
                            <th>Unit Price</th>
                            <th>Qty</th>
                            <th style="text-align:right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>${itemsRows}</tbody>
                </table>

                <div style="display: flex; justify-content: space-between;">
                    <div style="max-width: 300px;">
                        <div class="r-label" style="margin-bottom: 8px;">OFFICIAL STATEMENT</div>
                        <p style="font-size: 0.7rem; color: #444; line-height: 1.5;">Thank you for conducting business with ArcZen. This receipt serves as your official proof of purchase for the listed digital assets. For any support inquiries, please contact our terminal via live chat or email.</p>
                        <div style="font-weight: 800; font-size: 0.8rem; margin-top: 12px; color: #00C9BC;">WWW.ARCZEN.COM</div>
                    </div>
                    <div class="r-summary">
