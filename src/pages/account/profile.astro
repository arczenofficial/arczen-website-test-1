                                    </div>
                                    <div class="mo-arrow">→</div>
                                </div>
                            `).join('');
                        } else {
                            recentOrdersCard.classList.add('hidden');
                        }
                    }

                    // 2. Overview Tab: Active Order Box
                    const activeOrderStatusText = document.getElementById('activeOrderStatusText');
                    const activeOrderPulse = document.getElementById('activeOrderPulse');
                    const activeOrderBtn = document.getElementById('activeOrderBtn') as HTMLAnchorElement;

                    if (activeOrder) {
                        const baseText = `Current: Order #${activeOrder.id.slice(0,8).toUpperCase()} is ${STATUS_LABELS[activeOrder.status]}`;
                        const subText = STATUS_SUBTEXT[activeOrder.status] ? ` — ${STATUS_SUBTEXT[activeOrder.status]}` : '';
                        if (activeOrderStatusText) activeOrderStatusText.textContent = baseText + subText;
                        if (activeOrderPulse) activeOrderPulse.classList.remove('hidden');
                        if (activeOrderBtn) {
                            activeOrderBtn.textContent = 'Manage Order';
                            activeOrderBtn.href = '#';
