---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CartDrawer from '../../components/CartDrawer.astro';
---

<Layout title="My Account — ArcZen">
    <Header />

    <!-- Auth guard shown while loading -->
    <div id="authLoading" class="auth-loading">
        <div class="spinner"></div>
    </div>

    <!-- Main content — hidden until auth confirmed -->
    <div id="profileContent" class="profile-page hidden">
        <div class="profile-container">
            <!-- Sidebar -->
            <aside class="profile-sidebar">
                <div class="profile-avatar-block">
                    <div class="avatar-circle" id="avatarCircle">A</div>
                    <div class="profile-name-block">
                        <h2 id="sidebarDisplayName">Loading...</h2>
                        <p id="profileEmail" class="profile-email"></p>
                    </div>
                </div>
                <nav class="profile-nav" id="profileTabs">
                    <div class="nav-section-label">Account</div>
                    <button class="pnav-item active" data-tab="overview">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        Dashboard
                    </button>
                    <button class="pnav-item" data-tab="orders">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        Order History
                    </button>
                    <button class="pnav-item" data-tab="settings">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Personal Settings
                    </button>
                    <button class="pnav-item" data-tab="security">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        Security
                    </button>

                    <div class="nav-section-label">Shopping</div>
                    <a href="/store" class="pnav-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                        ArcZen Store
                    </a>

                    <div class="nav-section-label">Session</div>
                    <button id="signOutBtn" class="pnav-item pnav-danger">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Log Out
                    </button>
                    
                    <a href="/" class="pnav-back">
                        ← Back to Home
                    </a>
                </nav>
            </aside>

            <!-- Profile Content Area -->
            <section class="profile-main">
                <div id="orderSuccessCelebration" class="order-success-banner hidden">
                    <div class="celebration-content">
                        <div class="confetti-icon">🎉</div>
                        <div class="success-text">
                            <h3>Order Placed Successfully!</h3>
                            <p>Your order <strong id="successOrderId">#...</strong> has been received and is being verified.</p>
                        </div>
                        <button class="close-banner" onclick="this.parentElement.parentElement.classList.add('hidden')">×</button>
                    </div>
                </div>

                <div id="saveSuccess" class="save-toast success hidden">✅ Profile updated successfully!</div>
                <div id="saveError" class="save-toast error hidden">❌ Failed to update profile. Please try again.</div>

                <!-- Tab: Overview -->
                <div id="tab-overview" class="tab-content">
                    <div class="dashboard-hero">
                        <div class="hero-content">
                            <h1 id="heroWelcome">Welcome back, ArcZen Member</h1>
                            <p id="heroSummary">Here's a summary of your account and recent activities.</p>
                            
                            <!-- Active Order Status -->
                            <div id="activeOrderBox" class="active-order-box">
                                <div class="a-order-status">
                                    <span class="pulse-dot hidden" id="activeOrderPulse"></span>
                                    <span id="activeOrderStatusText">You haven't ordered any current purchases.</span>
                                </div>
                                <a href="/store" class="track-mini-btn" id="activeOrderBtn" style="text-decoration: none; display: inline-block; text-align: center;">Purchase Here</a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="grid-layout">
                        <!-- Recent Activity / Latest Orders -->
                        <div id="recentOrdersCard" class="dashboard-card full-width-card hidden">
                            <div class="card-header">
                                <h3>Recent Purchases</h3>
                                <button class="card-edit-tool" onclick="document.querySelector('[data-tab=orders]').click()">View All</button>
                            </div>
                            <div id="recentOrdersMiniList" class="mini-orders-grid">
                                <!-- Populated via Script -->
                            </div>
                        </div>
                        <!-- No Orders CTA Card -->
                        <div id="noOrdersCard" class="dashboard-card full-width-card hidden">
                            <div class="card-body" style="text-align: center; padding: 2rem 1rem;">
                                <div style="font-size: 3rem; margin-bottom: 1rem;">✨</div>
                                <h3 style="color: var(--gold); margin-bottom: 0.5rem; font-family: 'Playfair Display', serif;">Start Your Journey</h3>
                                <p style="color: var(--text-dim); margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
                                    No, you have nothing ordered yet. Order something here.
                                </p>
                                <a href="/store" class="save-btn" style="text-decoration: none; display: inline-block;">Purchase Here</a>
                            </div>
                        </div>

                        <div class="dashboard-card info-card">
                            <div class="card-header">
                                <h3>Account Details</h3>
                                <button class="card-edit-tool" onclick="document.querySelector('[data-tab=settings]').click()">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="detail-row">
                                    <span class="d-label">Email</span>
                                    <span class="d-value" id="viewEmail">—</span>
                                </div>
                                <div class="detail-row">
                                    <span class="d-label">Phone</span>
                                    <span class="d-value" id="viewPhone">Not provided</span>
                                </div>
                                <div class="detail-row">
                                    <span class="d-label">Joined</span>
                                    <span class="d-value" id="viewJoined">—</span>
                                </div>
                            </div>
                        </div>

                        <div class="dashboard-card address-card">
                            <div class="card-header">
                                <h3>Shipping Address</h3>
                            </div>
                            <div class="card-body">
                                <p class="address-text" id="viewAddress">No address saved yet</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab: Orders -->
                <div id="tab-orders" class="tab-content hidden">
                    <div class="main-header">
                        <h1 class="section-title">Order History</h1>
                        <p class="section-sub">Track and manage your digital purchases.</p>
                    </div>
                    
                    <div id="ordersLoading" class="empty-state">
                        <div class="spinner small"></div>
                        <p>Loading your orders...</p>
                    </div>

                    <div id="ordersEmpty" class="empty-state hidden">
                        <div class="empty-icon">🛍️</div>
                        <h3 style="color: var(--gold); margin-bottom: 0.5rem; font-family: 'Playfair Display', serif; font-size: 1.8rem;">No Orders Found</h3>
                        <p style="margin-bottom: 2rem; color: var(--text-dim);">Make your first order to see it here.</p>
                        <a href="/store" class="shop-btn" style="text-decoration: none; display: inline-block;">Purchase Now</a>
                    </div>

                    <div id="ordersList" class="orders-list"></div>
                </div>

                <!-- Tab: Settings -->
                <div id="tab-settings" class="tab-content hidden">
                    <div class="main-header">
                        <h1 class="section-title">Personal Settings</h1>
                        <p class="section-sub">Keep your contact and delivery details up to date.</p>
                    </div>
                    <form id="profileForm" class="profile-form" method="POST" onsubmit="return false">
                        <div id="nameChangeWarning" class="name-warning hidden">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            <span>Attention: You are eligible to update your name. This can only be done once every 30 days.</span>
                        </div>
                        <div class="form-row">
                            <div class="field-group" id="firstNameGroup">
                                <label for="firstName">First Name</label>
                                <input type="text" id="firstName" placeholder="First Name" />
                                <div id="firstNameLocked" class="locked-notice hidden">Locked for 30 days</div>
                            </div>
                            <div class="field-group" id="lastNameGroup">
                                <label for="lastName">Last Name</label>
                                <input type="text" id="lastName" placeholder="Last Name" />
                                <div id="lastNameLocked" class="locked-notice hidden">Locked for 30 days</div>
                            </div>
                        </div>
                        <div class="field-group">
                            <label for="editEmail">Email Address</label>
                            <input type="email" id="editEmail" disabled class="disabled-input" />
                            <span class="field-hint">Email cannot be changed online.</span>
                        </div>
                        <div class="field-group">
                            <label for="phone">Phone Number</label>
                            <div class="phone-input-group">
                                <select id="countryCode" class="country-select">
                                    <option value="+880">BD (+880)</option>
                                    <option value="+1">US (+1)</option>
                                    <option value="+44">UK (+44)</option>
                                    <option value="+971">UAE (+971)</option>
                                    <option value="+966">KSA (+966)</option>
                                    <option value="+60">MY (+60)</option>
                                    <option value="+65">SG (+65)</option>
                                    <option value="+91">IN (+91)</option>
                                </select>
                                <input type="tel" id="phone" placeholder="1XXXXXXXXX" />
                            </div>
                            <span id="phoneError" class="field-error hidden">Please enter a valid phone number</span>
                        </div>
                        <div class="field-group">
                            <label>Delivery Addresses</label>
                            <div id="addressList" class="address-list">
                                <!-- JS Injected Content -->
                            </div>
                            <button type="button" class="add-address-btn" id="addAddressBtn">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Add New Address
                            </button>
                        </div>
                        
                        <!-- Hidden Address Edit Form (Simple Modal-like) -->
                        <div id="addressEditSection" class="dashboard-card hidden" style="background: rgba(198, 167, 94, 0.05); margin-top: 1rem; border-style: dashed;">
                            <div class="card-header">
                                <h3 id="addrFormTitle">Add New Address</h3>
                            </div>
                            <div class="profile-form">
                                <div class="field-group">
                                    <label>Category / Label</label>
                                    <select id="addrLabel" class="country-select" style="width: 100%;">
                                        <option value="Home">Home</option>
                                        <option value="Office">Office</option>
                                        <option value="Work">Work</option>
                                        <option value="Billing">Billing</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="field-group">
                                    <label>Street Address</label>
                                    <textarea id="addrStreet" placeholder="House #, Road, Area..." rows="2"></textarea>
                                </div>
                                <div class="form-row">
                                    <div class="field-group">
                                        <label>City</label>
                                        <input type="text" id="addrCity" placeholder="City" />
                                    </div>
                                    <div class="field-group">
                                        <label>District</label>
                                        <input type="text" id="addrDistrict" placeholder="District" />
                                    </div>
                                </div>
                                <div class="form-actions" style="gap: 1rem;">
                                    <button type="button" id="saveAddrBtn" class="save-btn" style="padding: 0.8rem 1.5rem; font-size: 0.9rem;">Save Address</button>
                                    <button type="button" id="cancelAddrBtn" class="pnav-item" style="width: auto; height: 100%;">Cancel</button>
                                </div>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="save-btn" id="saveProfileBtn">
                                <span id="saveBtnText">Save Changes</span>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Tab: Security -->
                <div id="tab-security" class="tab-content hidden">
                    <div class="main-header">
                        <h1 class="section-title">Account Security</h1>
                        <p class="section-sub">Manage your password and account protection.</p>
                    </div>
                    
                    <div class="security-card">
                        <div id="passwordSecurity" class="full-width">
                            <div class="sec-info">
                                <h3>Change Password</h3>
                                <p id="secDescription">We'll send a secure password reset link to your email address.</p>
                            </div>
                            
                            <!-- Change Password Form (Hidden initially) -->
                            <form id="changePasswordForm" class="password-form hidden" method="POST" onsubmit="return false">
                                <div class="field-group">
                                    <label for="currentPassword">Current Password</label>
                                    <input type="password" id="currentPassword" required />
                                </div>
                                <div class="field-group">
                                    <label for="newPassword">New Password</label>
                                    <input type="password" id="newPassword" required minlength="6" />
                                </div>
                                <button type="submit" class="save-btn" style="width: 100%; margin-top: 1rem;">Update Password</button>
                            </form>

                            <div class="sec-actions" id="resetActions">
                                <button id="sendResetBtn" class="reset-btn">Send Reset Email</button>
                                <span id="resetSent" class="hidden reset-sent">✅ Check your inbox!</span>
                            </div>

                            <!-- Google Info -->
                            <div id="googleBadge" class="google-provider-badge hidden">
                                <svg width="20" height="20" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                                <span>Logged in with Google. Password managed by your Google Account.</span>
                            </div>
                        </div>
                    </div>

                    <div class="security-note">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                        <span>If you think your account has been compromised, please contact support immediately.</span>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <CartDrawer />
    <style is:global>
    /* Order Success Banner */
    .order-success-banner {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(16, 185, 129, 0.05));
        border: 1.5px solid rgba(16, 185, 129, 0.3);
        border-radius: 20px;
        padding: 1.5rem 2rem;
        margin-bottom: 2.5rem;
        position: relative;
        animation: slideDown 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        backdrop-filter: blur(10px);
    }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }
    .celebration-content { display: flex; align-items: center; gap: 1.5rem; }
    .confetti-icon { font-size: 2.5rem; animation: bounce 1s infinite alternate; }
    @keyframes bounce { from { transform: translateY(0); } to { transform: translateY(-5px); } }
    .success-text h3 { margin: 0; color: #34d399; font-family: 'Playfair Display', serif; font-size: 1.4rem; }
    .success-text p { margin: 5px 0 0; color: var(--text-dim); font-size: 0.95rem; }
    .success-text strong { color: var(--gold); }
    .close-banner { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; color: var(--text-dim); cursor: pointer; opacity: 0.6; transition: 0.2s; }
    .close-banner:hover { color: #fff; opacity: 1; }

    :root {
        --gold: #c6a75e;
        --gold-light: #e8c87a;
        --dark-bg: #0a0c10;
        --card-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(198, 167, 94, 0.15);
        --text-main: #f5f2eb;
        --text-dim: #9a9387;
        --error: #ef4444;
        --success: #10b981;
    }

    /* Override global body background for the dark-themed profile page */
    body:has(.profile-page),
    body:has(.auth-loading) {
        background: var(--dark-bg) !important;
    }

    .auth-loading { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--dark-bg); }
    .spinner { width: 40px; height: 40px; border: 3px solid rgba(198,167,94,0.1); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; }
    .spinner.small { width: 24px; height: 24px; margin: 0 auto 0.5rem; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .hidden { display: none !important; }

    .profile-page { 
        min-height: 100vh; 
        padding: 160px 2rem 80px; 
        background: radial-gradient(circle at 10% 20%, rgba(198,167,94,0.08) 0%, transparent 40%),
                    radial-gradient(circle at 90% 80%, rgba(198,167,94,0.05) 0%, transparent 40%),
                    var(--dark-bg);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }

    .profile-container { 
        max-width: 1200px; 
        margin: 0 auto; 
        display: grid; 
        grid-template-columns: 320px 1fr; 
        gap: 3rem; 
        align-items: start;
    }

    .profile-sidebar { 
        background: rgba(15, 17, 22, 0.8); 
        border: 1px solid var(--glass-border); 
        border-radius: 32px; 
        padding: 3rem 1.5rem; 
        position: sticky; 
        top: 160px;
        backdrop-filter: blur(30px);
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }

    .profile-avatar-block { display: flex; flex-direction: column; align-items: center; margin-bottom: 3rem; gap: 1.5rem; }
    .avatar-circle { 
        width: 100px; height: 100px; border-radius: 50%; 
        background: linear-gradient(135deg, var(--gold), var(--gold-light)); 
        color: #1a1200; font-size: 2.5rem; font-weight: 800; 
        display: flex; align-items: center; justify-content: center; 
        box-shadow: 0 10px 30px rgba(198,167,94,0.4);
        border: 4px solid rgba(255,255,255,0.1);
    }
    .profile-name-block h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; margin: 0; color: var(--text-main); text-align: center; }
    .profile-email { font-size: 0.9rem; color: var(--text-dim); margin-top: 0.5rem; opacity: 0.8; word-break: break-all; }

    .profile-nav { display: flex; flex-direction: column; gap: 8px; }
    .nav-section-label { 
        font-size: 0.75rem; 
        font-weight: 800; 
        color: var(--gold); 
        text-transform: uppercase; 
        letter-spacing: 0.2em; 
        margin: 2rem 0 1rem 12px;
        opacity: 0.6;
    }
    .nav-section-label:first-child { margin-top: 0; }
    
    .pnav-item { 
        display: flex; align-items: center; gap: 14px; 
        padding: 14px 20px; border-radius: 16px; 
        color: var(--text-dim); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: transparent; border: 1px solid transparent; 
        cursor: pointer; width: 100%; text-align: left; 
        font-family: inherit; font-size: 1rem; font-weight: 500;
    }
    .pnav-item svg { opacity: 0.6; transition: all 0.3s; }
    .pnav-item:hover { background: rgba(198,167,94,0.06); color: var(--gold-light); border-color: rgba(198,167,94,0.1); }
    .pnav-item:hover svg { opacity: 1; transform: scale(1.1); }
    .pnav-item.active { background: rgba(198, 167, 94, 0.12); color: var(--gold); border-color: rgba(198, 167, 94, 0.2); font-weight: 700; }
    .pnav-item.active svg { opacity: 1; }
    .pnav-danger:hover { background: rgba(239, 68, 68, 0.08); color: #f87171; border-color: rgba(239, 68, 68, 0.2); }
    
    .pnav-back { 
        display: block; margin-top: 2rem; padding: 15px 20px; 
        font-size: 0.9rem; color: var(--text-dim); transition: all 0.3s; 
        border-top: 1px solid rgba(255,255,255,0.05); text-decoration: none;
    }
    .pnav-back:hover { color: var(--gold); transform: translateX(-4px); }

    /* Main Area */
    .profile-main { min-height: 800px; animation: fadeIn 0.5s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Dashboard Hero */
    .dashboard-hero { 
        background: linear-gradient(135deg, rgba(198,167,94,0.15), rgba(10,12,16,0.6));
        border: 1px solid var(--glass-border); 
        border-radius: 32px; 
        padding: 4rem; 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        margin-bottom: 3rem;
        backdrop-filter: blur(10px);
        position: relative;
        overflow: hidden;
    }
    .dashboard-hero::before {
        content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
        background: radial-gradient(circle at center, rgba(198,167,94,0.1) 0%, transparent 70%);
        animation: pulse 10s infinite alternate;
    }
    @keyframes pulse { from { transform: translate(-10%, -10%); } to { transform: translate(10%, 10%); } }

    .hero-content h1 { font-family: 'Playfair Display', serif; font-size: 2.5rem; margin: 0 0 1rem; color: var(--text-main); }
    .hero-content p { color: var(--text-dim); font-size: 1.1rem; margin: 0; opacity: 0.9; }
    
