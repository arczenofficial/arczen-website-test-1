                                    <div class="item-price-qty"><div>৳${(item.price || 0).toLocaleString()}</div><div style="font-size: 0.75rem; color: #9a9387">Qty: ${item.quantity || 1}</div></div>
                                </div>
                                ${(o.fulfillment && o.fulfillment[item.uniqueId || item.id || idx]) ? `
                                    <div class="o-delivery-note" style="margin-top:0; margin-bottom:1rem; border-style:solid; border-width:1px;">
                                        <strong style="font-size:0.6rem;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:4px;"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.77 7.77a5.5 5.5 0 0 1 7.77-7.77zm0 0L22 22"/></svg> ITEM-SPECIFIC DELIVERY</strong>
                                        <code style="padding:0.75rem; font-size:0.75rem;">${o.fulfillment[item.uniqueId || item.id || idx].payload.replace(/\n/g, '<br>')}</code>
                                    </div>
                                ` : ''}
                            `).join('');

                            const subInfo = STATUS_SUBTEXT[status] || '';
                            const estTime = (status === 'confirmed' && o.estimatedTime) ? `<div style="font-size:0.8rem; color: var(--gold); margin-top:0.5rem;">🕒 Estimated Arrival: <strong>${o.estimatedTime}</strong></div>` : '';

                            const deliveryArea = (o.deliveryInfo) ? `
                                <div class="o-delivery-note">
                                    <strong><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:4px;"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.77 7.77 5.5 5.5 0 0 1 7.77-7.77zm0 0L22 22"/></svg> GLOBAL DELIVERY NOTES</strong>
                                    <code>${o.deliveryInfo.replace(/\n/g, '<br>')}</code>
                                    <p style="font-size:0.65rem; color:var(--text-dim); margin-top:10px;">* Please check both item-specific and global notes for your credentials.</p>
                                </div>
