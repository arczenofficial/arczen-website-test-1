                    const activeOrdersList = orders.filter((o: any) => ['pending', 'received', 'confirmed', 'in_progress', 'processing', 'shipped'].includes(o.status));
                    const activeOrder = activeOrdersList[0];

                    if (recentOrdersCard && recentOrdersMiniList) {
                        if (activeOrdersList.length > 0) {
                            recentOrdersCard.classList.remove('hidden');
                            const h3 = recentOrdersCard.querySelector('h3');
                            if (h3) h3.textContent = 'Active Orders';
