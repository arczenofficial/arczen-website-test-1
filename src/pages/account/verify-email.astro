---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Verify Email — ArcZen" description="Please verify your email address.">
    <Header />

    <div class="auth-page">
        <div class="container">
            <div class="auth-card">
                <div class="auth-brand">
                    <h1 class="auth-title">Verify Your Email</h1>
                    <p class="auth-sub">Check your inbox for a verification link.</p>
                </div>

                <div id="authError" class="auth-error hidden"></div>
                <div id="authSuccess" class="auth-success hidden"></div>

                <div class="verification-actions">
                    <p>You must verify your email address to unlock account features like placing orders.</p>
                    <button type="button" id="refreshBtn" class="primary-btn">I Have Verified</button>
                    <button type="button" id="resendBtn" class="secondary-btn" style="margin-top: 15px;">Resend Email</button>
                </div>

                <p class="auth-footer" style="margin-top: 25px;">
                    <a href="/">Return to Home</a>
                </p>
            </div>
        </div>
    </div>

    <Footer />
</Layout>

<style>
    .auth-page {
        padding: 8rem 1.5rem 6rem;
        background: radial-gradient(ellipse at 50% 0%, rgba(198,167,94,0.06) 0%, transparent 60%);
        min-height: 80vh;
    }
    .auth-page .container { display: flex; flex-direction: column; align-items: center; }
    .auth-card {
        width: 100%; max-width: 420px;
        background: rgba(26,23,20,0.8); backdrop-filter: blur(20px);
        border: 1px solid rgba(198,167,94,0.1); border-radius: 20px;
        padding: 2.5rem 2rem;
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }
    .auth-brand { text-align: center; margin-bottom: 2rem; }
    .auth-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #f5f2eb; margin: 0; }
    .auth-sub { color: #9a9387; font-size: 0.9rem; margin-top: 0.25rem; }
    
    .auth-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; margin-bottom: 1rem; }
    .auth-success { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3); color: #6ee7b7; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; margin-bottom: 1rem; }
    .hidden { display: none !important; }

    .verification-actions p {
        color: #f5f2eb;
        font-size: 0.95rem;
        text-align: center;
        line-height: 1.5;
        margin-bottom: 1.5rem;
    }

    .primary-btn { width: 100%; padding: 0.85rem; border-radius: 12px; border: none; background: linear-gradient(135deg, #c6a75e 0%, #e8c87a 100%); color: #1a1200; font-weight: 700; font-size: 0.9rem; letter-spacing: 0.05em; cursor: pointer; transition: all 0.2s; font-family: inherit; }
    .primary-btn:hover { box-shadow: 0 8px 24px rgba(198,167,94,0.4); transform: translateY(-1px); }
    .primary-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .secondary-btn { width: 100%; padding: 0.85rem; border-radius: 12px; border: 1px solid rgba(198,167,94,0.3); background: rgba(255,255,255,0.05); color: #f5f2eb; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; font-family: inherit; }
    .secondary-btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(198,167,94,0.5); }
    .secondary-btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .auth-footer { text-align: center; color: #9a9387; font-size: 0.85rem; }
    .auth-footer a { color: #c6a75e; text-decoration: none; }
    .auth-footer a:hover { color: #e8c87a; text-decoration: underline; }
</style>

<script>
    import { clientAuth } from '../../lib/firebase-client';
    import { onAuthStateChanged, sendEmailVerification } from 'firebase/auth';

    let currentUser: any = null;

    onAuthStateChanged(clientAuth, (user) => {
        currentUser = user;
        if (user) {
            if (user.emailVerified) {
                // Already verified
                window.location.replace('/');
            }
        } else {
            // Not logged in
            window.location.replace('/account/login');
        }
    });

    function showError(msg: string) {
        const el = document.getElementById('authError')!;
        el.textContent = msg;
        el.classList.remove('hidden');
        document.getElementById('authSuccess')?.classList.add('hidden');
    }

    function showSuccess(msg: string) {
        const el = document.getElementById('authSuccess')!;
        el.textContent = msg;
        el.classList.remove('hidden');
        document.getElementById('authError')?.classList.add('hidden');
    }

    document.getElementById('resendBtn')?.addEventListener('click', async (e) => {
        const btn = e.target as HTMLButtonElement;
        if (!currentUser) return;

        btn.disabled = true;
        btn.textContent = 'Sending...';

        try {
            await sendEmailVerification(currentUser);
            showSuccess('Verification email sent! Please check your inbox and spam folder.');
        } catch (err: any) {
            console.error(err);
            if (err.code === 'auth/too-many-requests') {
                showError('Too many requests. Please wait a few minutes before trying again.');
            } else {
                showError('Failed to send verification email. Try again later.');
            }
        } finally {
            btn.textContent = 'Resend Email';
            setTimeout(() => { btn.disabled = false; }, 30000); // 30s cooldown
        }
    });

    document.getElementById('refreshBtn')?.addEventListener('click', async (e) => {
        const btn = e.target as HTMLButtonElement;
        if (!currentUser) return;

        btn.disabled = true;
        btn.textContent = 'Checking...';

        try {
            await currentUser.reload();
            if (currentUser.emailVerified) {
                showSuccess('Email verified successfully! Redirecting...');
                setTimeout(() => window.location.replace('/'), 1500);
            } else {
                showError('Email is not verified yet. Please check your inbox.');
            }
        } catch (err: any) {
            console.error(err);
            showError('Error checking status.');
        } finally {
            btn.textContent = 'I Have Verified';
            btn.disabled = false;
        }
    });
</script>
