---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CartDrawer from '../../components/CartDrawer.astro';
---

<Layout title="Create Account — ArcZen" description="Join ArcZen to track your orders and manage your profile.">
    <link rel="stylesheet" href="/styles/auth.css">
    <Header />

    <div class="auth-page">
        <div class="container">

            <div class="auth-card">
                <!-- Config Warning -->
                <div id="configWarning" class="auth-error hidden" style="background:rgba(245,158,11,0.1); border-color:rgba(245,158,11,0.3); color:#fbbf24;">
                    ⚠️ <strong>System Notice:</strong> Firebase not configured. Please check your .env file or follow the Setup Guide.
                </div>

                <div class="auth-brand">
                    <h1 class="auth-title">Create Account</h1>
                    <p class="auth-sub">Join the ArcZen community today</p>
                </div>

                <!-- Google sign up — no action/method -->
                <button id="googleBtn" type="button" class="google-btn">
                    <svg width="18" height="18" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.29-8.16 2.29-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                    </svg>
                    Continue with Google
                </button>

                <div class="auth-divider"><span>or</span></div>

                <div id="authError" class="auth-error hidden"></div>
                <!-- onsubmit=return false prevents any native form submission -->
                <form id="registerForm" class="auth-form" onsubmit="return false">
                    <div class="field-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" required placeholder="Your name" autocomplete="name" />
                    </div>
                    <div class="field-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" required placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <div class="field-group">
                        <label for="phone">Phone <span class="optional">(optional)</span></label>
                        <div class="phone-input-group">
                            <select id="countryCode" class="country-select">
                                <option value="+880">BD (+880)</option>
                                <option value="+1">US (+1)</option>
                                <option value="+44">UK (+44)</option>
                                <option value="+971">UAE (+971)</option>
                                <option value="+966">KSA (+966)</option>
                                <option value="+60">MY (+60)</option>
                                <option value="+65">SG (+65)</option>
                                <option value="+91">IN (+91)</option>
                            </select>
                            <input type="tel" id="phone" placeholder="1XXXXXXXXX" autocomplete="tel" />
                        </div>
                        <span id="phoneError" class="field-error hidden">Please enter a valid phone number</span>
                    </div>
                    <div class="field-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" required placeholder="At least 8 characters" autocomplete="new-password" minlength="8" />
                    </div>
                    <button type="submit" id="registerBtn" class="primary-btn">
                        <span id="registerBtnText">Create Account</span>
                    </button>
                </form>

                <p class="auth-footer">
                    Already have an account? <a href="/account/login">Sign in</a>
                </p>
            </div>
        </div>
    </div>

    <CartDrawer />
    <Footer />
</Layout>

<style>
    /* Content is now in auth.css */
    .phone-input-group { display: flex; gap: 8px; }
    .country-select { 
        width: 110px; padding: 0.75rem 0.5rem; 
        background: rgba(255,255,255,0.04); 
        border: 1.5px solid rgba(198,167,94,0.12); 
        border-radius: 10px; color: #f5f2eb; 
        font-size: 0.85rem; outline: none; cursor: pointer; 
    }
    .country-select:focus { border-color: rgba(198,167,94,0.4); }
    .phone-input-group input { flex: 1; }
    .field-error { font-size: 0.75rem; color: #f87171; margin-top: 0.3rem; font-weight: 600; }
</style>

<script>
    import { clientAuth, clientDb, isConfigured, logActivity } from '../../lib/firebase-client';
    import {
        createUserWithEmailAndPassword,
        updateProfile,
        GoogleAuthProvider,
        signInWithPopup,
        onAuthStateChanged,
        sendEmailVerification
    } from 'firebase/auth';
    import { doc, setDoc, serverTimestamp } from 'firebase/firestore';

    // Show config warning if needed
    if (!isConfigured) {
        document.getElementById('configWarning')?.classList.remove('hidden');
    }

    // Redirect if already logged in (unless actively registering)
    let isRegistering = false;
    onAuthStateChanged(clientAuth, (user) => {
        // Only redirect if a user exists AND we aren't in the middle of a registration flow
        // The registration flow handles its own redirect after seeding the profile.
        if (user && !isRegistering && !window.location.pathname.includes('register')) {
            if (!user.emailVerified) {
                window.location.replace('/account/verify-email');
            } else {
                window.location.replace('/');
            }
        }
    });

    function showError(msg: string, code?: string) {
        const el = document.getElementById('authError')!;
        el.textContent = code ? `${msg} (${code})` : msg;
        el.classList.remove('hidden');
    }
    function clearError() {
        document.getElementById('authError')?.classList.add('hidden');
    }

    async function seedCustomerProfile(user: any, name: string, phone: string) {
        const parts = (name || '').trim().split(' ');
        const firstName = parts[0] || '';
        const lastName = parts.slice(1).join(' ') || '';

        await setDoc(doc(clientDb, 'customers', user.uid), {
            uid: user.uid,
            name: name || user.displayName || '',
            firstName,
            lastName,
            email: user.email,
            phone: phone || null,
            addresses: [],
            createdAt: serverTimestamp(),
            lastLoginAt: serverTimestamp(),
            totalOrders: 0,
            totalSpent: 0,
            loyaltyPoints: 0,
            isActive: true,
            role: 'customer',
        }, { merge: true });
    }

    // Google
    document.getElementById('googleBtn')?.addEventListener('click', async () => {
        clearError();
        isRegistering = true;
        try {
            const result = await signInWithPopup(clientAuth, new GoogleAuthProvider());
            await seedCustomerProfile(result.user, result.user.displayName || '', '');
            logActivity('register', { method: 'google', page: '/account/register' });
            if (!result.user.emailVerified) {
                window.location.replace('/account/verify-email');
            } else {
                window.location.replace('/');
            }
        } catch (e: any) {
            showError(e.message || 'Google sign-up failed.');
            isRegistering = false;
        }
    });

    // Email registration
    document.getElementById('registerForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearError();
        isRegistering = true;

        if (!isConfigured) {
            showError('Firebase is not configured. Contact support.');
            isRegistering = false;
            return;
        }

        const btn      = document.getElementById('registerBtn') as HTMLButtonElement;
        const btnText  = document.getElementById('registerBtnText')!;
        const name     = (document.getElementById('name') as HTMLInputElement).value.trim();
        const email    = (document.getElementById('email') as HTMLInputElement).value.trim();
        const countryCode = (document.getElementById('countryCode') as HTMLSelectElement).value;
        const phonePart   = (document.getElementById('phone') as HTMLInputElement).value.trim().replace(/^0+/, '');
        const password = (document.getElementById('password') as HTMLInputElement).value;

        // Phone validation
        const phoneErr = document.getElementById('phoneError')!;
        if (phonePart && !/^\d{7,14}$/.test(phonePart)) {
            phoneErr.classList.remove('hidden');
            isRegistering = false;
            return;
        }
        phoneErr.classList.add('hidden');

        const fullPhone = phonePart ? `${countryCode} ${phonePart}` : '';

        btn.disabled = true;
        btnText.textContent = 'Creating account…';

        try {
            const { user } = await createUserWithEmailAndPassword(clientAuth, email, password);
            
            // Set name in Auth profile
            await updateProfile(user, { displayName: name });
            
            // CRITICAL: Ensure DB record is created BEFORE moving on
            // This is what ensures they show up in the Admin Panel
            await seedCustomerProfile(user, name, fullPhone);
            
            // Send verification email
            await sendEmailVerification(user);

            // Log registration to activity feed
            await logActivity('register', { 
                method: 'email', 
                page: '/account/register',
                fullName: name
            });
            
            // Show success feedback
            btnText.textContent = 'Verification email sent. Redirecting...';
            btn.style.background = 'linear-gradient(135deg, #10b981 0%, #34d399 100%)';
            btn.style.boxShadow = '0 8px 24px rgba(16,185,129,0.4)';
            
            // Short delay to let user see success and Firestore propagate
            setTimeout(() => {
                window.location.replace('/account/verify-email');
            }, 1000);

        } catch (err: any) {
            console.error('Registration error:', err);
            const msgs: Record<string, string> = {
                'auth/email-already-in-use':   'An account with this email already exists.',
                'auth/weak-password':          'Password must be at least 8 characters.',
                'auth/invalid-email':          'Please enter a valid email address.',
                'auth/operation-not-allowed':  'Email/Password registration is not enabled.',
                'permission-denied':           'Could not save profile. Please contact support.'
            };
            showError(msgs[err.code] || 'Registration failed. Please try again.', err.code);
            btn.disabled = false;
            btnText.textContent = 'Create Account';
            isRegistering = false;
        }
    });
</script>
