---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CartDrawer from '../../components/CartDrawer.astro';
---

<Layout title="Reset Password — ArcZen">
    <Header />

    <div class="auth-page">
        <div class="container">
            <a href="/account/login" class="auth-back-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Back to Sign In
            </a>

            <div class="auth-card">
                <!-- Config Warning -->
                <div id="configWarning" class="auth-error hidden" style="background:rgba(245,158,11,0.1); border-color:rgba(245,158,11,0.3); color:#fbbf24;">
                    ⚠️ <strong>System Notice:</strong> Firebase not configured. Please check your .env file or follow the Setup Guide.
                </div>

                <div class="auth-brand">
                    <img src="/images/logo.png" alt="ArcZen" class="auth-logo" />
                    <h1 class="auth-title">Reset Password</h1>
                    <p class="auth-sub">Enter your email and we'll send a reset link</p>
                </div>

                <div id="authSuccess" class="auth-success hidden">
                    ✅ Reset link sent! Check your email inbox.
                </div>
                <div id="authError" class="auth-error hidden"></div>

                <form id="resetForm" class="auth-form">
                    <div class="field-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" required placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <button type="submit" id="resetBtn" class="primary-btn">
                        <span id="resetBtnText">Send Reset Link</span>
                    </button>
                </form>

                <p class="auth-footer">
                    Don't have an account? <a href="/account/register">Create one</a>
                </p>
            </div>
        </div>
    </div>

    <CartDrawer />
    <Footer />
</Layout>

<style>
    .auth-page {
        padding: 8rem 1.5rem 6rem;
        background: radial-gradient(ellipse at 50% 0%, rgba(198,167,94,0.06) 0%, transparent 60%);
    }

    .auth-page .container {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .auth-back-link {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #9a9387;
        font-size: 0.9rem;
        margin-bottom: 2rem;
        transition: color 0.2s;
        align-self: flex-start;
        max-width: 420px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }
    .auth-back-link:hover {
        color: #c6a75e;
    }

    .auth-card {
        width: 100%; max-width: 420px;
        background: rgba(26,23,20,0.8); backdrop-filter: blur(20px);
        border: 1px solid rgba(198,167,94,0.1); border-radius: 20px;
        padding: 2.5rem 2rem;
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }
    .auth-brand { text-align: center; margin-bottom: 2rem; }
    .auth-logo { height: 60px; width: auto; margin: 0 auto 0.75rem; display: block; }
    .auth-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #f5f2eb; margin: 0; }
    .auth-sub { color: #9a9387; font-size: 0.9rem; margin-top: 0.25rem; }
    .auth-success { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3); color: #6ee7b7; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; margin-bottom: 1rem; }
    .auth-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; margin-bottom: 1rem; }
    .auth-success.hidden, .auth-error.hidden { display: none; }
    .auth-form { display: flex; flex-direction: column; gap: 1rem; }
    .field-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .field-group label { font-size: 0.82rem; font-weight: 600; color: #c6a75e; }
    .field-group input { padding: 0.75rem 1rem; background: rgba(255,255,255,0.04); border: 1.5px solid rgba(198,167,94,0.12); border-radius: 10px; color: #f5f2eb; font-size: 0.9rem; font-family: inherit; outline: none; transition: border-color 0.2s; }
    .field-group input:focus { border-color: rgba(198,167,94,0.4); }
    .primary-btn { width: 100%; padding: 0.85rem; border-radius: 12px; border: none; background: linear-gradient(135deg, #c6a75e 0%, #e8c87a 100%); color: #1a1200; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; font-family: inherit; margin-top: 0.5rem; }
    .primary-btn:hover { box-shadow: 0 8px 24px rgba(198,167,94,0.4); transform: translateY(-1px); }
    .primary-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .auth-footer { text-align: center; color: #9a9387; font-size: 0.85rem; margin-top: 1.5rem; }
    .auth-footer a { color: #c6a75e; }
</style>

<script>
    import { clientAuth, isConfigured } from '../../lib/firebase-client';
    import { sendPasswordResetEmail } from 'firebase/auth';

    // Show config warning if needed
    if (!isConfigured) {
        document.getElementById('configWarning')?.classList.remove('hidden');
    }

    document.getElementById('resetForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn     = document.getElementById('resetBtn') as HTMLButtonElement;
        const btnText = document.getElementById('resetBtnText')!;
        const email   = (document.getElementById('email') as HTMLInputElement).value.trim();

        btn.disabled = true;
        btnText.textContent = 'Sending...';

        try {
            await sendPasswordResetEmail(clientAuth, email);
            document.getElementById('authSuccess')!.classList.remove('hidden');
            document.getElementById('authError')!.classList.add('hidden');
            document.getElementById('resetForm')!.classList.add('hidden');
        } catch (err: any) {
            const msgs: Record<string, string> = {
                'auth/user-not-found': 'No account found with this email.',
                'auth/invalid-email':  'Please enter a valid email address.',
            };
            document.getElementById('authError')!.textContent = msgs[err.code] || 'Failed to send reset link.';
            document.getElementById('authError')!.classList.remove('hidden');
            btn.disabled = false;
            btnText.textContent = 'Send Reset Link';
        }
    });
</script>
