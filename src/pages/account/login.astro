---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CartDrawer from '../../components/CartDrawer.astro';
import WishlistDrawer from '../../components/WishlistDrawer.astro';
---

<Layout title="Login — ArcZen" description="Sign in to your ArcZen account to view orders and manage your profile.">
    <Header />

    <div class="auth-page">
        <div class="container">

            <div class="auth-card">
                <!-- Config Warning -->
                <div id="configWarning" class="auth-error hidden" style="background:rgba(245,158,11,0.1); border-color:rgba(245,158,11,0.3); color:#fbbf24;">
                    ⚠️ <strong>System Notice:</strong> Firebase not configured. Please check your .env file or contact the developer.
                </div>

                <div class="auth-brand">
                    <h1 class="auth-title">Welcome Back</h1>
                    <p class="auth-sub">Log in to your ArcZen account</p>
                </div>

                <!-- Google Sign In -->
                <button id="googleBtn" class="google-btn" type="button">
                    <svg width="18" height="18" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.29-8.16 2.29-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                    </svg>
                    Continue with Google
                </button>

                <div class="auth-divider"><span>or</span></div>

                <!-- Email form — no action/method so it never does a native POST -->
                <div id="authError" class="auth-error hidden"></div>
                <form id="loginForm" class="auth-form" method="POST" onsubmit="return false">
                    <div class="field-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <div class="field-group">
                        <label for="password">
                            Password
                            <a href="/account/reset-password" class="forgot-link">Forgot?</a>
                        </label>
                        <input type="password" id="password" name="password" required placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <button type="submit" id="loginBtn" class="primary-btn">
                        <span id="loginBtnText">Sign In</span>
                    </button>
                </form>

                <p class="auth-footer">
                    Don't have an account?
                    <a href="/account/register">Create one</a>
                </p>
            </div>
        </div>
    </div>

    <CartDrawer />
    <WishlistDrawer />
    <Footer />
</Layout>

<style>
    .auth-page {
        padding: 8rem 1.5rem 6rem;
        background: radial-gradient(ellipse at 50% 0%, rgba(198,167,94,0.06) 0%, transparent 60%);
    }

    .auth-page .container {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .auth-card {
        width: 100%; max-width: 420px;
        background: rgba(26,23,20,0.8); backdrop-filter: blur(20px);
        border: 1px solid rgba(198,167,94,0.1); border-radius: 20px;
        padding: 2.5rem 2rem;
        box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    }

    .auth-brand { text-align: center; margin-bottom: 2rem; }
    .auth-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #f5f2eb; margin: 0; }
    .auth-sub { color: #9a9387; font-size: 0.9rem; margin-top: 0.25rem; }

    .google-btn {
        display: flex; align-items: center; justify-content: center; gap: 12px;
        width: 100%; padding: 0.8rem; border-radius: 12px;
        background: rgba(255,255,255,0.06); border: 1.5px solid rgba(255,255,255,0.1);
        color: #f5f2eb; font-size: 0.9rem; font-weight: 500; cursor: pointer;
        transition: all 0.2s; font-family: inherit;
    }
    .google-btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); }

    .auth-divider {
        display: flex; align-items: center; gap: 12px;
        color: #9a9387; font-size: 0.8rem; margin: 1.5rem 0;
    }
    .auth-divider::before, .auth-divider::after {
        content: ''; flex: 1; height: 1px; background: rgba(198,167,94,0.15);
    }

    .auth-error {
        background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5; padding: 0.75rem 1rem; border-radius: 8px;
        font-size: 0.85rem; margin-bottom: 1rem;
    }
    .auth-error.hidden { display: none; }

    .auth-form { display: flex; flex-direction: column; gap: 1rem; }

    .field-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .field-group label {
        font-size: 0.82rem; font-weight: 600; color: #c6a75e;
        display: flex; justify-content: space-between;
    }
    .forgot-link { color: #9a9387; font-weight: 400; }
    .forgot-link:hover { color: #c6a75e; }
    .field-group input {
        padding: 0.75rem 1rem; background: rgba(255,255,255,0.04);
        border: 1.5px solid rgba(198,167,94,0.12); border-radius: 10px;
        color: #f5f2eb; font-size: 0.9rem; font-family: inherit;
        transition: border-color 0.2s; outline: none;
    }
    .field-group input:focus { border-color: rgba(198,167,94,0.4); background: rgba(255,255,255,0.06); }

    .primary-btn {
        width: 100%; padding: 0.85rem; border-radius: 12px; border: none;
        background: linear-gradient(135deg, #c6a75e 0%, #e8c87a 100%);
        color: #1a1200; font-weight: 700; font-size: 0.9rem; letter-spacing: 0.05em;
        cursor: pointer; transition: all 0.2s; font-family: inherit;
        margin-top: 0.5rem;
    }
    .primary-btn:hover { box-shadow: 0 8px 24px rgba(198,167,94,0.4); transform: translateY(-1px); }
    .primary-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .auth-footer { text-align: center; color: #9a9387; font-size: 0.85rem; margin-top: 1.5rem; }
    .auth-footer a { color: #c6a75e; transition: color 0.2s; }
    .auth-footer a:hover { color: #e8c87a; }
</style>

<script>
    import { clientAuth, isConfigured, logActivity } from '../../lib/firebase-client';
    import {
        signInWithEmailAndPassword,
        GoogleAuthProvider,
        signInWithPopup,
        onAuthStateChanged
    } from 'firebase/auth';

    // Show config warning if needed
    if (!isConfigured) {
        const w = document.getElementById('configWarning');
        if (w) w.classList.remove('hidden');
    }

    // Redirect if already logged in
    onAuthStateChanged(clientAuth, (user) => {
        if (user) {
            if (!user.emailVerified) {
                window.location.replace('/account/verify-email');
            } else {
                window.location.replace('/account/profile');
            }
        }
    });

    function showError(msg: string, code?: string) {
        const el = document.getElementById('authError')!;
        el.textContent = code ? `${msg} (${code})` : msg;
        el.classList.remove('hidden');
    }
    function clearError() {
        document.getElementById('authError')?.classList.add('hidden');
    }

    // Google Sign In
    document.getElementById('googleBtn')?.addEventListener('click', async () => {
        clearError();
        try {
            const result = await signInWithPopup(clientAuth, new GoogleAuthProvider());
            logActivity('login', { method: 'google', page: '/account/login' });
            if (!result.user.emailVerified) {
                window.location.replace('/account/verify-email');
            } else {
                window.location.replace('/account/profile');
            }
        } catch (e: any) {
            const msgs: Record<string, string> = {
                'auth/popup-closed-by-user': 'Sign-in was cancelled.',
                'auth/unauthorized-domain':  'This domain is not authorised for Google sign-in.',
            };
            showError(msgs[e.code] || e.message || 'Google sign-in failed.', e.code);
        }
    });

    // Email login
    document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearError();

        if (!isConfigured) {
            showError('Firebase is not configured. Contact support.');
            return;
        }

        const btn     = document.getElementById('loginBtn') as HTMLButtonElement;
        const btnText = document.getElementById('loginBtnText')!;
        const email   = (document.getElementById('email') as HTMLInputElement).value.trim();
        const pass    = (document.getElementById('password') as HTMLInputElement).value;

        btn.disabled = true;
        btnText.textContent = 'Signing in…';

        try {
            const userCred = await signInWithEmailAndPassword(clientAuth, email, pass);
            logActivity('login', { method: 'email', page: '/account/login' });
            if (!userCred.user.emailVerified) {
                window.location.replace('/account/verify-email');
            } else {
                window.location.replace('/account/profile');
            }
        } catch (err: any) {
            const msgs: Record<string, string> = {
                'auth/invalid-credential':    'Incorrect email or password.',
                'auth/user-not-found':        'No account found with this email.',
                'auth/wrong-password':        'Incorrect password.',
                'auth/too-many-requests':     'Too many attempts. Please try again later.',
                'auth/operation-not-allowed': 'Email/Password login is not enabled.',
                'auth/invalid-email':         'Please enter a valid email address.',
            };
            showError(msgs[err.code] || 'Sign-in failed. Please try again.', err.code);
            btn.disabled = false;
            btnText.textContent = 'Sign In';
        }
    });
</script>
