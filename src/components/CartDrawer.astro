---
---
<div class="cart-overlay" id="cart-overlay"></div>
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-head">
    <div class="cart-head-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cart-icon-main"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        Your Shopping Bag 
        <span id="cart-count-badge" class="badge-gold">0</span>
    </div>
    <button class="cart-x" id="cart-close" aria-label="Close Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div class="cart-items" id="cart-items">
    <!-- Populated via Javascript -->
    <div class="cart-empty">
        <div class="cart-empty-icon">🛍️</div>
        <p>Your bag is empty.</p>
        <a href="/store" class="btn-shop-now">Browse Catalog</a>
    </div>
  </div>
  
  <div class="cart-foot" id="cart-foot" style="display:none">
    <div class="cart-summary">
        <div class="sum-row subtotal">
            <span>Subtotal</span>
            <span id="cart-total">৳0</span>
        </div>
        <p class="tax-info">Taxes and delivery calculated at checkout.</p>
    </div>
    
    <div class="cart-buttons">
        <a href="/checkout" class="btn-checkout" id="cart-checkout-btn">
            Secure Checkout
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <button class="btn-clear" id="cart-clear-btn">Clear All Items</button>
    </div>
  </div>
</div>

<style>
:root {
    --gold: #c6a75e;
    --gold-bright: #e8c87a;
    --bg-dark: #080a0c;
    --bg-card: #1a1714;
    --text-main: #f5f2eb;
    --text-dim: #9a9387;
}

.cart-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.7);
  z-index: 1999; opacity: 0; pointer-events: none;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); backdrop-filter: blur(8px);
}
.cart-overlay.open { opacity: 1; pointer-events: all; }

.cart-drawer {
  position: fixed; top: 0; right: -100%; width: 440px;
  max-width: 100vw; height: 100vh;
  background: var(--bg-dark); border-left: 1px solid rgba(198, 167, 94, 0.15);
  z-index: 2000; display: flex; flex-direction: column;
  transition: right 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden; box-shadow: -20px 0 50px rgba(0,0,0,0.5);
}
.cart-drawer.open { right: 0; }

.cart-head {
  padding: 30px; border-bottom: 1px solid rgba(198, 167, 94, 0.1);
  display: flex; align-items: center; justify-content: space-between;
}
.cart-head-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 800; display:flex; align-items:center; gap: 12px; color: var(--text-main); }
.cart-icon-main { color: var(--gold); }
.badge-gold { background: rgba(198, 167, 94, 0.15); color: var(--gold); font-size: 0.75rem; padding: 2px 10px; border-radius: 100px; font-family: sans-serif; font-weight: 900; }

.cart-x {
  width: 38px; height: 38px; border-radius: 50%;
  background: rgba(255,255,255,0.03); border: 1px solid rgba(198,167,94,0.1);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--text-dim); transition: all 0.3s;
}
.cart-x:hover { background: rgba(239, 68, 68, 0.1); color: #f87171; border-color: rgba(239, 68, 68, 0.3); transform: rotate(90deg); }

.cart-items { flex: 1; overflow-y: auto; padding: 30px; display: flex; flex-direction: column; gap: 16px; scrollbar-width: none; }
.cart-items::-webkit-scrollbar { display: none; }

/* Item Card */
.cart-item {
  display: flex; gap: 16px; background: var(--bg-card);
  border: 1px solid rgba(255,255,255,0.03); border-radius: 16px; padding: 16px; position: relative;
  transition: transform 0.2s;
}
.cart-item:hover { transform: translateX(-4px); border-color: rgba(198, 167, 94, 0.15); }

.ci-img-box { width: 72px; height: 72px; border-radius: 12px; overflow: hidden; background: #12141a; border: 1px solid rgba(255,255,255,0.05); flex-shrink: 0; position: relative; }
.ci-img { width: 100%; height: 100%; object-fit: cover; }
.ci-emoji { font-size: 2.2rem; display: flex; align-items: center; justify-content: center; height: 100%; width: 100%; }

.ci-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.ci-name { font-size: 0.95rem; font-weight: 700; color: var(--text-main); line-height: 1.4; padding-right: 25px; }
.ci-variant { font-size: 0.75rem; color: var(--text-dim); margin-top: 2px; }
.ci-price { font-size: 0.95rem; color: var(--gold); font-weight: 800; margin-top: 4px; }

.ci-actions { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; }
.ci-qty { display: flex; align-items: center; gap: 12px; background: rgba(0,0,0,0.2); padding: 4px 8px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); }
.qty-btn { background: none; border: none; color: var(--text-dim); width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; cursor: pointer; transition: color 0.2s; }
.qty-btn:hover { color: var(--gold); }
.qty-n { font-size: 0.85rem; font-weight: 800; color: var(--text-main); width: 16px; text-align: center; }

.ci-remove { position: absolute; top: 16px; right: 16px; background: none; border: none; color: #444; cursor: pointer; transition: color 0.2s; }
.ci-remove:hover { color: #f87171; }

/* Foot */
.cart-foot { padding: 30px; background: #0a0e12; border-top: 1px solid rgba(198, 167, 94, 0.15); box-shadow: 0 -10px 30px rgba(0,0,0,0.3); }
.cart-summary { margin-bottom: 24px; }
.sum-row { display: flex; justify-content: space-between; align-items: flex-end; }
.sum-row span:first-child { font-size: 1rem; color: var(--text-dim); font-weight: 600; }
.sum-row span:last-child { font-size: 1.6rem; color: var(--gold); font-weight: 900; font-family: 'Playfair Display', serif; }
.tax-info { font-size: 0.75rem; color: #555; margin-top: 8px; }

.cart-buttons { display: flex; flex-direction: column; gap: 12px; }
.btn-checkout {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    background: linear-gradient(135deg, #c6a75e, #e8c87a); color: #1a1200;
    padding: 18px; border-radius: 14px; text-decoration: none; font-weight: 800; font-size: 1rem;
    transition: all 0.3s;
}
.btn-checkout:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(198, 167, 94, 0.4); }

.btn-clear { background: none; border: none; color: #555; font-size: 0.8rem; font-weight: 600; cursor: pointer; text-decoration: underline; transition: color 0.2s; }
.btn-clear:hover { color: #f87171; }

.cart-empty { text-align: center; padding: 60px 20px; }
.cart-empty-icon { font-size: 4rem; margin-bottom: 20px; filter: drop-shadow(0 0 10px rgba(198, 167, 94, 0.1)); }
.btn-shop-now { display: inline-block; background: rgba(198, 167, 94, 0.1); color: var(--gold); border: 1.5px solid rgba(198, 167, 94, 0.3); padding: 12px 24px; border-radius: 12px; text-decoration: none; font-weight: 700; margin-top: 15px; transition: all 0.2s; }
.btn-shop-now:hover { background: var(--gold); color: #1a1200; }
</style>

<script>
    import { isCartOpen, cartItems, updateQuantity, clearCart } from '../store';

    const overlay = document.getElementById('cart-overlay');
    const drawer = document.getElementById('cart-drawer');
    const closeBtn = document.getElementById('cart-close');
    
    isCartOpen.subscribe(isOpen => {
        if (!drawer || !overlay) return;
        if (isOpen) {
            drawer.classList.add('open');
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        } else {
            drawer.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = '';
        }
    });

    closeBtn?.addEventListener('click', () => isCartOpen.set(false));
    overlay?.addEventListener('click', () => isCartOpen.set(false));
    document.getElementById('cart-checkout-btn')?.addEventListener('click', () => isCartOpen.set(false));

    document.getElementById('cart-clear-btn')?.addEventListener('click', () => {
        if (confirm('Empty your bag?')) clearCart();
    });

    cartItems.subscribe(items => {
        const container = document.getElementById('cart-items');
        const foot = document.getElementById('cart-foot');
        const badge = document.getElementById('cart-count-badge');
        const totalEl = document.getElementById('cart-total');

        if (!container) return;

        let totalQty = 0;
        let totalPrice = 0;

        if(items.length === 0) {
            container.innerHTML = `
                <div class="cart-empty">
                    <div class="cart-empty-icon">🛍️</div>
                    <p style="font-size:0.95rem; color:#9a9387">Your shopping bag is currently empty.</p>
                    <a href="/store" class="btn-shop-now">Explore Catalog</a>
                </div>`;
            if(foot) foot.style.display = 'none';
            if(badge) badge.textContent = '0';
            return;
        }

        container.innerHTML = '';
        items.forEach((item: any) => {
            totalQty += item.quantity;
            totalPrice += (item.price * item.quantity);

            const div = document.createElement('div');
            div.className = 'cart-item';
            
            const hasImage = item.productImage && (item.productImage.startsWith('http') || item.productImage?.includes('/'));
            const imageHtml = hasImage ? 
                `<img src="${item.productImage}" alt="${item.productTitle}" class="ci-img"/>` : 
                `<div class="ci-emoji">${item.image_emoji || '📦'}</div>`;

            div.innerHTML = `
                <div class="ci-img-box">${imageHtml}</div>
                <div class="ci-info">
                    <div>
                        <div class="ci-name">${item.productTitle}</div>
                        <div class="ci-variant">${item.variantLabel || 'Single Edition'}</div>
                    </div>
                    <div class="ci-price">৳${(item.price * item.quantity).toLocaleString()}</div>
                    <div class="ci-actions">
                        <div class="ci-qty">
                            <button class="qty-btn" onclick="window.updateCartQty('${item.id}', ${item.quantity - 1})">−</button>
                            <span class="qty-n">${item.quantity}</span>
                            <button class="qty-btn" onclick="window.updateCartQty('${item.id}', ${item.quantity + 1})">+</button>
                        </div>
                    </div>
                </div>
                <button class="ci-remove" onclick="window.updateCartQty('${item.id}', 0)" title="Remove item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                </button>
            `;
            container.appendChild(div);
        });

        if(foot) foot.style.display = 'block';
        if(badge) badge.textContent = totalQty.toString();
        if(totalEl) totalEl.textContent = `৳${totalPrice.toLocaleString()}`;
    });

    // Global helper for the inline onclicks (cleaner than multiple listeners in loops)
    (window as any).updateCartQty = (id: string, qty: number) => {
        updateQuantity(id, qty);
    };
</script>
