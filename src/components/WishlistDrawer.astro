---
/**
 * ArcZen Wishlist Drawer
 * ─────────────────────────────────────────────────────────────────────────────
 * A premium sliding drawer for saved items.
 * Uses nanostores for real-time reactivity without page reloads.
 */
---

<div id="wishlist-drawer" class="drawer-overlay hidden">
  <div class="drawer-content">
    <div class="drawer-header">
      <div class="header-left">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="header-icon">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.78-8.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
        <div class="header-text">
          <h2>My Wishlist</h2>
          <span id="wishlist-count" class="count-badge">0 Items</span>
        </div>
      </div>
      <button id="close-wishlist" class="close-btn" aria-label="Close Wishlist">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div id="wishlist-items" class="drawer-items">
      <!-- Empty State -->
      <div id="wishlist-empty" class="empty-state">
        <div class="empty-icon">✨</div>
        <h3>Your wishlist is empty</h3>
        <p>Save items you love to find them easily later.</p>
        <a href="/store" class="continue-shopping">Explore Store</a>
      </div>
      
      <!-- Items will be injected here by JS -->
    </div>

    <div class="drawer-footer">
       <button id="move-all-to-cart" class="primary-action-btn">
         <span>Move All to Bag</span>
         <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
       </button>
    </div>
  </div>
</div>

<style>
  .drawer-overlay {
    position: fixed; inset: 0; z-index: 2000;
    background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(8px);
    display: flex; justify-content: flex-end;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0; pointer-events: none;
  }
  .drawer-overlay:not(.hidden) { opacity: 1; pointer-events: auto; }

  .drawer-content {
    width: 100%; max-width: 420px; height: 100%;
    background: #110f0d; border-left: 1px solid rgba(198, 167, 94, 0.15);
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: -20px 0 60px rgba(0,0,0,0.8);
  }
  .drawer-overlay:not(.hidden) .drawer-content { transform: translateX(0); }

  /* Header */
  .drawer-header {
    padding: 2.5rem 2rem;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .header-left { display: flex; align-items: center; gap: 1rem; }
  .header-icon { color: #ff4757; filter: drop-shadow(0 0 8px rgba(255,71,87,0.3)); }
  .header-text h2 { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: #f5f2eb; margin: 0; font-weight: 800; }
  .count-badge { font-size: 0.75rem; color: #c6a75e; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }

  .close-btn { background: none; border: none; color: #9a9387; cursor: pointer; padding: 8px; border-radius: 50%; transition: all 0.2s; }
  .close-btn:hover { background: rgba(255, 255, 255, 0.05); color: #f5f2eb; transform: rotate(90deg); }

  /* Items List */
  .drawer-items { flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
  
  .empty-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; }
  .empty-icon { font-size: 3.5rem; margin-bottom: 1.5rem; opacity: 0.8; filter: grayscale(1) brightness(1.5); }
  .empty-state h3 { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: #f5f2eb; margin-bottom: 0.5rem; }
  .empty-state p { color: #9a9387; font-size: 0.95rem; line-height: 1.6; max-width: 240px; margin-bottom: 2rem; }
  .continue-shopping { display: inline-block; padding: 12px 28px; background: rgba(198, 167, 94, 0.1); border: 1px solid #c6a75e; color: #c6a75e; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 0.9rem; transition: all 0.2s; }
  .continue-shopping:hover { background: #c6a75e; color: #1a1200; transform: translateY(-2px); }

  /* Footer */
  .drawer-footer { padding: 2rem; border-top: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2); }
  .primary-action-btn { width: 100%; padding: 1.1rem; border: none; border-radius: 16px; background: linear-gradient(135deg, #c6a75e, #e8c87a); color: #1a1200; font-weight: 800; font-size: 1rem; display: flex; align-items: center; justify-content: center; gap: 12px; cursor: pointer; transition: all 0.3s; }
  .primary-action-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(198,167,94,0.3); }
</style>

<script>
  // Placeholder logic for wishlist - will be connected to real store later
  const overlay = document.getElementById('wishlist-drawer');
  const closeBtn = document.getElementById('close-wishlist');

  function openWishlist() { overlay?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closeWishlist() { overlay?.classList.add('hidden'); document.body.style.overflow = ''; }

  closeBtn?.addEventListener('click', closeWishlist);
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeWishlist(); });

  // Expose to window for global triggers
  (window as any).openWishlist = openWishlist;
</script>
